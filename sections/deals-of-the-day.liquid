<section class="w-full py-10 bg-white">
  <div class="max-w-[1440px] mx-auto px-4">
    
    <div class="flex items-center justify-between bg-[#24D125] text-white px-6 py-3 rounded-t-xl">
      <h2 class="font-bold uppercase tracking-tight">{{ section.settings.title }}</h2>
      <a href="{{ section.settings.view_all_link }}" class="text-sm hover:underline">View All</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 border-x border-b border-gray-100 rounded-b-xl overflow-hidden bg-white">
      
      <div class="lg:col-span-9 p-8 flex flex-col md:flex-row gap-8 relative">
        
        <div class="hidden md:flex flex-col gap-3">
          {% for i in (1..4) %}
            <div class="w-12 h-16 border border-gray-100 rounded overflow-hidden cursor-pointer hover:border-green-500">
              <img src="https://via.placeholder.com/100x150" class="object-cover w-full h-full">
            </div>
          {% endfor %}
        </div>

        <div class="flex-1 relative flex justify-center items-center">
          <div class="absolute top-0 left-0 bg-[#24D125] text-white px-3 py-1 rounded-md text-sm font-bold">
            SAVE <br> $199.00
          </div>
          <img src="https://via.placeholder.com/400x500" class="max-h-[400px] object-contain">
        </div>

        <div class="flex-1">
          <div class="text-gray-400 text-sm mb-1">(12)</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 leading-tight">
            Xioma Redmi Note 11 Pro 256GB 2023, Black Smartphone
          </h3>

          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl font-bold text-[#E52E2E]">$569.00</span>
            <span class="text-gray-400 line-through">$759.00</span>
          </div>

          <ul class="text-xs text-gray-600 space-y-2 mb-6">
            <li class="flex items-start gap-2">• Intel LGA 1700 Socket: Supports 13th & 12th Gen Intel Core</li>
            <li class="flex items-start gap-2">• DDR5 Compatible: 4*SMD DIMMs with XMP 3.0 Memory</li>
            <li class="flex items-start gap-2">• Commanding Power Design: Twin 16+1+2 Phases Digital VRM</li>
          </ul>

          <div class="flex gap-2 mb-8">
            <span class="bg-green-50 text-green-600 text-[10px] px-2 py-1 font-bold rounded">FREE SHIPPING</span>
            <span class="bg-red-50 text-red-500 text-[10px] px-2 py-1 font-bold rounded">FREE GIFT</span>
          </div>

          <div class="flex items-center gap-4 mb-6">
            <p class="text-[10px] font-bold uppercase leading-tight text-gray-700">Hurry Up!<br>Promotion will<br>expires in</p>
            <div class="flex gap-1">
              {% render 'countdown-box', number: '-162', label: 'd' %}
              {% render 'countdown-box', number: '9', label: 'h' %}
              {% render 'countdown-box', number: '32', label: 'm' %}
              {% render 'countdown-box', number: '34', label: 's' %}
            </div>
          </div>

          <div class="space-y-2">
            <div class="w-full bg-gray-100 h-2 rounded-full overflow-hidden">
              <div class="bg-[#24D125] h-full" style="width: 35%;"></div>
            </div>
            <p class="text-xs text-gray-500">Sold: <span class="font-bold text-black">26/75</span></p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-3 p-4 bg-gray-50 flex flex-col gap-4">
        {% for block in section.blocks %}
          {% if block.type == 'banner' %}
            <div class="rounded-xl overflow-hidden h-1/3">
              <img src="{{ block.settings.image | image_url }}" class="w-full h-full object-cover">
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="mt-6 bg-[#18C41A] rounded-2xl p-6 flex items-center justify-center text-center text-white relative overflow-hidden">
       <div class="relative z-10 flex items-center gap-2 flex-wrap justify-center">
         <span>🌟 Member get <strong class="text-yellow-300">FREE SHIPPING*</strong> with no order minimum!. *Restriction apply</span>
         <a href="#" class="underline font-bold">Try free 30-days trial!</a>
       </div>
       <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-10 -mt-10"></div>
    </div>

  </div>
</section>

<style>
  .countdown-box {
    @apply bg-gray-100 rounded-md p-2 min-w-[45px] text-center;
  }
</style>


{% schema %}
{
  "name": "Deals of the Day",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Deals of the Day" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Sidebar Banner",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Banner Image" }
      ]
    }
  ],
  "presets": [{ "name": "Deals of the Day" }]
}
{% endschema %}