<!-- Top Bar -->
<div class="swoo-topbar">
  <div class="swoo-topbar__inner">

    <!-- Left: Hotline -->
    <div class="swoo-topbar__left">
      <span class="swoo-topbar__badge">{{ section.settings.hotline_label }}</span>
      <span class="swoo-topbar__phone">{{ section.settings.hotline_number }}</span>
    </div>

    <!-- Right: Links + Currency + Language -->
    <div class="swoo-topbar__right">
      <a href="{{ section.settings.top_link_1_url }}" class="swoo-topbar__link">{{ section.settings.top_link_1_text }}</a>
      <a href="{{ section.settings.top_link_2_url }}" class="swoo-topbar__link">{{ section.settings.top_link_2_text }}</a>

      <!-- Currency -->
      <div class="swoo-topbar__dropdown" tabindex="0">
        <span>USD</span>
        <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
      </div>

      <!-- Language -->
      <div class="swoo-topbar__dropdown swoo-topbar__lang" tabindex="0">
        <span class="swoo-topbar__flag" aria-hidden="true">
          <svg width="20" height="14" viewBox="0 0 20 14" fill="none">
            <rect width="20" height="14" rx="2" fill="#B22234"/>
            <rect y="1.077" width="20" height="1.846" fill="white"/>
            <rect y="3.846" width="20" height="1.846" fill="#B22234"/>
            <rect y="5.692" width="20" height="2.615" fill="white"/>
            <rect y="9.231" width="20" height="1.846" fill="#B22234"/>
            <rect y="11.077" width="20" height="1.846" fill="white"/>
            <rect width="8" height="7.538" fill="#3C3B6E"/>
          </svg>
        </span>
        <span>Eng</span>
        <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
      </div>
    </div>

  </div>
</div>

<!-- Main Header -->
<header class="swoo-header">
  <div class="swoo-header__inner">

    <!-- Logo -->
    <div class="swoo-header__logo">
      {% if section.settings.logo_image %}
        <img src="{{ section.settings.logo_image | image_url: width: 120 }}" alt="{{ shop.name }}" class="swoo-header__logo-img">
      {% else %}
        <div class="swoo-header__logo-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
          </svg>
        </div>
        <div class="swoo-header__logo-text">
          <span class="swoo-header__logo-main" style="color: {{ section.settings.brand_color }}">{{ section.settings.logo_text_main | upcase }}</span>
          <span class="swoo-header__logo-sub">{{ section.settings.logo_text_sub | upcase }}</span>
        </div>
      {% endif %}
    </div>

    <!-- Navigation -->
    <nav class="swoo-nav" aria-label="Main navigation">
      {% for link in linklists[section.settings.main_menu].links %}
        <div class="swoo-nav__item {% if link.links.size > 0 %}swoo-nav__item--has-children{% endif %}">
          <a href="{{ link.url }}" class="swoo-nav__link {% if link.active %}swoo-nav__link--active{% endif %}">
            {{ link.title | upcase }}
            {% if link.links.size > 0 %}
              <svg class="swoo-nav__chevron" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
              </svg>
            {% endif %}
          </a>
          {% if link.links.size > 0 %}
            <div class="swoo-nav__dropdown">
              {% for child in link.links %}
                <a href="{{ child.url }}" class="swoo-nav__dropdown-item">{{ child.title }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </nav>

    <!-- Actions -->
    <div class="swoo-header__actions">

      <!-- Wishlist -->
      <a href="/wishlist" class="swoo-action-btn" aria-label="Wishlist">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </a>

      <!-- Account -->
      <div class="swoo-account">
        <div class="swoo-action-btn" aria-label="Account">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        {% if section.settings.show_account_labels %}
        <div class="swoo-account__text">
          <p class="swoo-account__welcome">Welcome</p>
          {% if customer %}
            <p class="swoo-account__action"><a href="/account">{{ customer.first_name }}</a></p>
          {% else %}
            <p class="swoo-account__action"><a href="/account/login">Log In / Register</a></p>
          {% endif %}
        </div>
        {% endif %}
      </div>

      <!-- Cart -->
      <div class="swoo-cart">
        <a href="/cart" class="swoo-action-btn swoo-action-btn--cart" aria-label="Cart">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <span class="swoo-cart__badge" id="cart-count">{{ cart.item_count }}</span>
        </a>
        {% if section.settings.show_account_labels %}
        <div class="swoo-account__text">
          <p class="swoo-account__welcome">Cart</p>
          <p class="swoo-account__action swoo-account__action--price">{{ cart.total_price | money }}</p>
        </div>
        {% endif %}
      </div>

    </div>
  </div>
</header>

<style>
  /* ── Top Bar ── */
  .swoo-topbar {
    width: 100%;
    height: 44px;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #555;
  }
  .swoo-topbar__inner {
    max-width: 100%;
    height: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 24px;
  }
  .swoo-topbar__left {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .swoo-topbar__badge {
    background: #f3f4f6;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 12px;
    color: #555;
    font-weight: 500;
  }
  .swoo-topbar__phone {
    font-weight: 700;
    color: #111;
    font-size: 13.5px;
    letter-spacing: 0.01em;
  }
  .swoo-topbar__right {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .swoo-topbar__link {
    color: #555;
    text-decoration: none;
    font-size: 13px;
    transition: color 0.15s;
  }
  .swoo-topbar__link:hover { color: #16a34a; }
  .swoo-topbar__dropdown {
    display: flex;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    color: #333;
    font-size: 13px;
    padding-left: 16px;
    border-left: 1px solid #e5e7eb;
    user-select: none;
  }
  .swoo-topbar__lang {
    border-left: none;
    padding-left: 0;
  }
  .swoo-topbar__flag {
    display: flex;
    align-items: center;
    border-radius: 2px;
    overflow: hidden;
  }

  /* ── Main Header ── */
  .swoo-header {
    width: 100%;
    background: #fff;
    padding: 14px 0;
    border-bottom: 1px solid #f0f0f0;
    font-family: 'Inter', sans-serif;
  }
  .swoo-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    gap: 16px;
  }

  /* Logo */
  .swoo-header__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    text-decoration: none;
  }
  .swoo-header__logo-img {
    height: 44px;
    width: auto;
  }
  .swoo-header__logo-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: #16a34a;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .swoo-header__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .swoo-header__logo-main {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .swoo-header__logo-sub {
    font-size: 11px;
    font-weight: 600;
    color: #6b7280;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Navigation */
  .swoo-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    padding-left: 40px;
  }
  .swoo-nav__item {
    position: relative;
  }
  .swoo-nav__link {
    display: flex;
    align-items: center;
    gap: 3px;
    padding: 8px 10px;
    font-size: 13px;
    font-weight: 600;
    color: #111;
    text-decoration: none;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: color 0.15s;
    border-radius: 6px;
  }
  .swoo-nav__link:hover,
  .swoo-nav__link--active { color: #16a34a; }
  .swoo-nav__chevron {
    opacity: 0.6;
    transition: transform 0.2s;
  }
  .swoo-nav__item:hover .swoo-nav__chevron { transform: rotate(180deg); }

  /* Dropdown */
  .swoo-nav__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 180px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
    padding: 6px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.18s ease;
    z-index: 100;
  }
  .swoo-nav__item:hover .swoo-nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .swoo-nav__dropdown-item {
    display: block;
    padding: 9px 12px;
    font-size: 13px;
    color: #333;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
  }
  .swoo-nav__dropdown-item:hover {
    background: #f0fdf4;
    color: #16a34a;
  }

  /* Action Buttons */
  .swoo-header__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .swoo-action-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #f9fafb;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111;
    text-decoration: none;
    transition: background 0.15s;
    position: relative;
    flex-shrink: 0;
  }
  .swoo-action-btn:hover { background: #f3f4f6; }

  /* Cart badge */
  .swoo-cart__badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #16a34a;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: 999px;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* Account/Cart text labels */
  .swoo-account,
  .swoo-cart {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .swoo-account__text {
    display: none;
  }
  .swoo-account__welcome {
    font-size: 10px;
    color: #9ca3af;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    line-height: 1.2;
  }
  .swoo-account__action {
    font-size: 13px;
    font-weight: 800;
    color: #111;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.2;
  }
  .swoo-account__action a {
    color: inherit;
    text-decoration: none;
  }
  .swoo-account__action--price {
    text-transform: none;
  }

  @media (min-width: 1280px) {
    .swoo-account__text { display: block; }
  }
  @media (max-width: 1024px) {
    .swoo-nav { display: none; }
  }
</style>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "header",
      "content": "Top Bar Settings"
    },
    {
      "type": "text",
      "id": "hotline_label",
      "label": "Hotline Label",
      "default": "Hotline 24/7"
    },
    {
      "type": "text",
      "id": "hotline_number",
      "label": "Hotline Number",
      "default": "(025) 3886 25 16"
    },
    {
      "type": "text",
      "id": "top_link_1_text",
      "label": "Top Link 1 Text",
      "default": "Sell on Swoo"
    },
    {
      "type": "url",
      "id": "top_link_1_url",
      "label": "Top Link 1 URL"
    },
    {
      "type": "text",
      "id": "top_link_2_text",
      "label": "Top Link 2 Text",
      "default": "Order Tracking"
    },
    {
      "type": "url",
      "id": "top_link_2_url",
      "label": "Top Link 2 URL"
    },
    {
      "type": "header",
      "content": "Brand & Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image (Optional)"
    },
    {
      "type": "text",
      "id": "logo_text_main",
      "label": "Logo Text Main",
      "default": "Swoo"
    },
    {
      "type": "text",
      "id": "logo_text_sub",
      "label": "Logo Text Subtitle",
      "default": "Tech Mart"
    },
    {
      "type": "color",
      "id": "brand_color",
      "label": "Brand Accent Color",
      "default": "#16a34a"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_account_labels",
      "label": "Show Account/Cart Labels",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "currency",
      "name": "Currency Picker",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "currency_code",
          "label": "Default Currency",
          "default": "USD"
        }
      ]
    },
    {
      "type": "language",
      "name": "Language Picker",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "lang_code",
          "label": "Language Code",
          "default": "Eng"
        }
      ]
    }
  ]
}
{% endschema %}
